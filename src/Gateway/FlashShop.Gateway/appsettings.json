{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "JwtSettings": {
    "Issuer": "FlashShop.Identity",
    "Audience": "FlashShop",
    "SecretKey": "ThisIsAVeryLongSecretKeyForJwtToken2024FlashShop!@#$%",
    "ExpiryInMinutes": 60
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all=}"
        }
      },
      "users-route": {
        "ClusterId": "identity-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/users/{**catch-all=}"
        }
      },
      "wallets-route": {
        "ClusterId": "identity-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/wallets/{**catch-all=}"
        }
      },
      "categories-route": {
        "ClusterId": "catalog-cluster",
        "Match": {
          "Path": "/api/categories/{**catch-all=}"
        }
      },
      "products-route": {
        "ClusterId": "catalog-cluster",
        "Match": {
          "Path": "/api/products/{**catch-all=}"
        }
      },
      "flashsales-route": {
        "ClusterId": "catalog-cluster",
        "Match": {
          "Path": "/api/flashsales/{**catch-all=}"
        }
      },
      "testimonials-route": {
        "ClusterId": "catalog-cluster",
        "Match": {
          "Path": "/api/testimonials/{**catch-all=}"
        }
      },
      "stocks-route": {
        "ClusterId": "inventory-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/stocks/{**catch-all=}"
        }
      },
      "cart-route": {
        "ClusterId": "ordering-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/cart/{**catch-all=}"
        }
      },
      "orders-route": {
        "ClusterId": "ordering-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/orders/{**catch-all=}"
        }
      },
      "notifications-route": {
        "ClusterId": "notification-cluster",
        "Match": {
          "Path": "/api/notifications/{**catch-all=}"
        }
      },
      "identity-swagger-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/swagger-doc/identity/{**catch-all=}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/swagger-doc/identity" },
          { "PathPrefix": "/swagger" }
        ]
      },
      "catalog-swagger-route": {
        "ClusterId": "catalog-cluster",
        "Match": {
          "Path": "/swagger-doc/catalog/{**catch-all=}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/swagger-doc/catalog" },
          { "PathPrefix": "/swagger" }
        ]
      },
      "inventory-swagger-route": {
        "ClusterId": "inventory-cluster",
        "Match": {
          "Path": "/swagger-doc/inventory/{**catch-all=}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/swagger-doc/inventory" },
          { "PathPrefix": "/swagger" }
        ]
      },
      "ordering-swagger-route": {
        "ClusterId": "ordering-cluster",
        "Match": {
          "Path": "/swagger-doc/ordering/{**catch-all=}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/swagger-doc/ordering" },
          { "PathPrefix": "/swagger" }
        ]
      },
      "notification-swagger-route": {
        "ClusterId": "notification-cluster",
        "Match": {
          "Path": "/swagger-doc/notification/{**catch-all=}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/swagger-doc/notification" },
          { "PathPrefix": "/swagger" }
        ]
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://identity-api:8080"
          }
        }
      },
      "catalog-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://catalog-api:8080"
          }
        }
      },
      "inventory-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://inventory-api:8080"
          }
        }
      },
      "ordering-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://ordering-api:8080"
          }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://notification-api:8080"
          }
        }
      }
    }
  }
}
