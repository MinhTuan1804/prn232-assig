{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "JwtSettings": {
    "Issuer": "FlashShop.Identity",
    "Audience": "FlashShop",
    "SecretKey": "ThisIsAVeryLongSecretKeyForJwtToken2024FlashShop!@#$%",
    "ExpiryInMinutes": 60
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all=}"
        }
      },
      "users-route": {
        "ClusterId": "identity-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/users/{**catch-all=}"
        }
      },
      "wallets-route": {
        "ClusterId": "identity-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/wallets/{**catch-all=}"
        }
      },
      "categories-route": {
        "ClusterId": "catalog-cluster",
        "Match": {
          "Path": "/api/categories/{**catch-all=}"
        }
      },
      "products-route": {
        "ClusterId": "catalog-cluster",
        "Match": {
          "Path": "/api/products/{**catch-all=}"
        }
      },
      "flashsales-route": {
        "ClusterId": "catalog-cluster",
        "Match": {
          "Path": "/api/flashsales/{**catch-all=}"
        }
      },
      "testimonials-route": {
        "ClusterId": "catalog-cluster",
        "Match": {
          "Path": "/api/testimonials/{**catch-all=}"
        }
      },
      "stocks-route": {
        "ClusterId": "inventory-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/stocks/{**catch-all=}"
        }
      },
      "cart-route": {
        "ClusterId": "ordering-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/cart/{**catch-all=}"
        }
      },
      "orders-route": {
        "ClusterId": "ordering-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/orders/{**catch-all=}"
        }
      },
      "notifications-route": {
        "ClusterId": "notification-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/notifications/{**catch-all=}"
        }
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5000"
          }
        }
      },
      "catalog-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5010"
          }
        }
      },
      "inventory-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5020"
          }
        }
      },
      "ordering-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5030"
          }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5040"
          }
        }
      }
    }
  }
}
